# ============================================================
# FERRY GOOD — .gitignore
# ============================================================

# ── Environment variables ────────────────────────────────────
.env
.env.local
.env.development
.env.production
api-server/.env
frontend/.env
frontend/.env.local

# ── Node modules ─────────────────────────────────────────────
node_modules/
api-server/node_modules/
frontend/node_modules/

# ── Next.js build output ─────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/.swc/

# ── Next.js cache ────────────────────────────────────────────
frontend/.next/cache/
frontend/.next/static/chunks/
frontend/.next/server/
*.hot-update.js
*.hot-update.json
*.hot-update.js.map

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo
frontend/next-env.d.ts

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ── MS Access — never commit database files ──────────────────
*.accdb
*.mdb
*.ldb
*.laccdb

# ── MS Access backups and manifests ──────────────────────────
database/Backups/
database/Manifests/
*_Backup_*.accdb
FerryGood_Temp.accdb

# ── Test scripts ─────────────────────────────────────────────
api-server/test-db.js
api-server/hash-passwords.js

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── VS Code ──────────────────────────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ── Misc ─────────────────────────────────────────────────────
*.gz
*.tgz
*.zip
.history/
.cache/
coverage/
.nyc_output/